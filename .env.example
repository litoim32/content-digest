# Copy to .env and fill values. Never commit .env.
# Add variables here as the project grows.

# Optional: a free CoinGecko "Demo" API key for higher rate limits.
# Without it, the app uses the keyless public API (charts may hit 429 limits).
# Get one at https://www.coingecko.com/en/api  →  paste below, then restart dev.
# VITE_COINGECKO_API_KEY=your-demo-key-here
