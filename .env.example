# Copy to .env (or set in Vercel project settings). Never commit real secrets.

# OpenRouter — used by the /api/digest endpoint (server-side only).
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-key-here
# Optional: override the model (default: openai/gpt-4o-mini)
# OPENROUTER_MODEL=openai/gpt-4o-mini

# Postgres connection string (used from issue #7 onward).
# DATABASE_URL=postgres://user:password@host:5432/dbname
